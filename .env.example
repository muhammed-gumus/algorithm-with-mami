# Güvenli bir JWT secret belirleyin (min 32 karakter)
# Üretmek için: openssl rand -base64 48
JWT_SECRET=

# Admin paneli şifresi
ADMIN_PASSWORD=

# GitHub Gist ile kalıcı soru depolama (Vercel için önerilir)
# 1) GitHub'da bir Gist oluşturun ve problems.json dosyası ekleyin
# 2) Gist ID ve token bilgilerini girin
GITHUB_GIST_ID=
GITHUB_TOKEN=

# Opsiyonel: Gist içindeki JSON dosya adı (varsayılan: problems.json)
GITHUB_GIST_FILENAME=problems.json
